# ═══════════════════════════════════════════════════════════════
# CHAYAN — Government Jobs Portal
# Environment Variables Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Never commit the real .env file to git.
# ═══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
# Local:    postgresql://postgres:postgres@localhost:5432/govjobs?schema=public
# Neon:     postgresql://user:pass@ep-*.us-east-2.aws.neon.tech/govjobs?sslmode=require
# Supabase: postgresql://postgres:pass@db.xxx.supabase.co:5432/postgres?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/govjobs?schema=public"

# ─── NextAuth (Authentication) ────────────────────────────────
# Generate with: openssl rand -hex 32  (or `npx auth secret`)
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"

# ─── App URL ──────────────────────────────────────────────────
# Public URL of your deployed site. Used for sitemap, RSS, robots.txt, metadata.
# Local:    http://localhost:3000
# Vercel:   https://chayan.vercel.app
# Custom:   https://chayan.in
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Google OAuth (Optional — for Google Sign-In) ─────────────
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an OAuth 2.0 Client ID (Web application)
# 3. Add authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 4. Copy the Client ID and Secret here
# Leave blank to disable Google Sign-In.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Resend (Optional — for transactional emails) ─────────────
# Sign up at https://resend.com → API Keys → Create API Key
# Used for: password reset emails, notifications.
RESEND_API_KEY=""

# ─── Redis (Optional — for caching) ───────────────────────────
# Used for: session caching, rate limiting, job view counters.
REDIS_URL="redis://localhost:6379"

# ─── Google Search Console (Optional — verification) ──────────
# 1. Go to https://search.google.com/search-console
# 2. Add your domain and choose "HTML tag" verification method
# 3. Copy the "content" value from the meta tag and paste here
# Leave blank if not using Search Console yet.
GOOGLE_SEARCH_CONSOLE_ID=""

# ─── Cloudinary (Optional — for image uploads) ────────────────
# Sign up at https://cloudinary.com → Dashboard
# Used for: admin panel image uploads (job notifications, banners).
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Google AdSense (Optional — for ads) ────────────────────────
# 1. Get approved at https://adsense.google.com
# 2. Copy your publisher ID (ca-pub-XXXXXXXXXXXXXXXX)
# 3. Set it here to enable ads across the site
# Leave blank to show placeholder ad spaces only.
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=""

# ─── Google Analytics (Optional — for traffic tracking) ─────────
# 1. Go to https://analytics.google.com → Create a new GA4 property
# 2. Copy your Measurement ID (G-XXXXXXXXXX)
# 3. Set it here to enable tracking across the site
# Leave blank to disable Google Analytics.
NEXT_PUBLIC_GA_ID=""
