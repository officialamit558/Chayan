generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum JobStatus {
  ACTIVE
  EXPIRED
  UPCOMING
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  password        String?
  image           String?
  role            Role      @default(USER)
  emailVerified   DateTime?
  phone           String?
  resetToken      String?   @unique
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bookmark                 Bookmark[]
  comment                  Comment[]
  log                      Log[]
  notificationPreference   NotificationPreference?
  userNotification         UserNotification[]

  @@index([email])
  @@index([role])
  @@index([resetToken])
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  jobAlerts       Boolean @default(true)
  resultAlerts    Boolean @default(true)
  admitCardAlerts Boolean @default(false)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  slug      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

model AdminUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  job         Job[]
  result      Result[]
  admitCard   AdmitCard[]
  answerKey   AnswerKey[]
  admission   Admission[]
  syllabus    Syllabus[]
  notification Notification[]
  exam        Exam[]

  @@index([name])
  @@index([slug])
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  job         Job[]
  result      Result[]
  admitCard   AdmitCard[]
  answerKey   AnswerKey[]
  admission   Admission[]
  syllabus    Syllabus[]

  @@index([name])
  @@index([slug])
}

model State {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  job       Job[]

  @@index([name])
  @@index([slug])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

model Job {
  id                 String     @id @default(cuid())
  title              String
  slug               String     @unique
  departmentId       String
  categoryId         String
  stateId            String?
  advertisementNo    String?
  totalVacancies     Int?
  salary             String?
  location           String?
  ageLimit           String?
  ageRelaxation      String?
  education          String?
  selectionProcess   String?
  applicationFee     String?
  importantDates     Json?
  documentsRequired  String?
  howToApply         String?
  officialNotification String?
  officialWebsite    String?
  applyLink          String?
  status             JobStatus  @default(ACTIVE)
  experience         String?
  startDate          DateTime?
  lastDate           DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  department         Department @relation(fields: [departmentId], references: [id])
  category           Category   @relation(fields: [categoryId], references: [id])
  state              State?     @relation(fields: [stateId], references: [id])
  result             Result[]
  admitCard          AdmitCard[]
  answerKey          AnswerKey[]
  syllabus           Syllabus[]
  bookmark           Bookmark[]
  comment            Comment[]
  jobView            JobView[]

  @@index([title])
  @@index([slug])
  @@index([status])
  @@index([departmentId])
  @@index([categoryId])
  @@index([stateId])
}

model Result {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  departmentId String
  categoryId   String
  jobId        String?
  pdfUrl       String?
  resultDate   DateTime?
  status       String?
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  job          Job?       @relation(fields: [jobId], references: [id])
  bookmark     Bookmark[]
  comment      Comment[]

  @@index([title])
  @@index([slug])
  @@index([departmentId])
  @@index([categoryId])
  @@index([jobId])
}

model AdmitCard {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  departmentId String
  categoryId   String
  jobId        String?
  examDate     DateTime?
  downloadUrl  String?
  status       String?
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  job          Job?       @relation(fields: [jobId], references: [id])
  bookmark     Bookmark[]

  @@index([title])
  @@index([slug])
  @@index([departmentId])
  @@index([categoryId])
  @@index([jobId])
}

model AnswerKey {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  departmentId String
  categoryId   String
  jobId        String?
  pdfUrl       String?
  status       String?
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  job          Job?       @relation(fields: [jobId], references: [id])

  @@index([title])
  @@index([slug])
  @@index([departmentId])
  @@index([categoryId])
  @@index([jobId])
}

model Admission {
  id              String     @id @default(cuid())
  title           String
  slug            String     @unique
  description     String?
  departmentId    String
  categoryId      String
  startDate       DateTime?
  lastDate        DateTime?
  applicationFee  String?
  pdfUrl          String?
  status          String?
  createdAt       DateTime   @default(now())
  department      Department @relation(fields: [departmentId], references: [id])
  category        Category   @relation(fields: [categoryId], references: [id])

  @@index([title])
  @@index([slug])
  @@index([departmentId])
  @@index([categoryId])
}

model Syllabus {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  description  String?
  departmentId String
  categoryId   String
  jobId        String?
  pdfUrl       String?
  subjects     String?
  status       String?
  createdAt    DateTime   @default(now())
  department   Department @relation(fields: [departmentId], references: [id])
  category     Category   @relation(fields: [categoryId], references: [id])
  job          Job?       @relation(fields: [jobId], references: [id])

  @@index([title])
  @@index([slug])
  @@index([departmentId])
  @@index([categoryId])
  @@index([jobId])
}

model Notification {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String?
  categoryId String
  type       String?
  isTrending Boolean  @default(false)
  views      Int      @default(0)
  createdAt  DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id])

  @@index([title])
  @@index([slug])
  @@index([categoryId])
  @@index([isTrending])
}

model Exam {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  categoryId  String
  createdAt   DateTime @default(now())
  category    Category @relation(fields: [categoryId], references: [id])

  @@index([name])
  @@index([slug])
  @@index([categoryId])
}

model Bookmark {
  id          String     @id @default(cuid())
  userId      String
  jobId       String?
  resultId    String?
  admitCardId String?
  createdAt   DateTime   @default(now())
  user        User       @relation(fields: [userId], references: [id])
  job         Job?       @relation(fields: [jobId], references: [id])
  result      Result?    @relation(fields: [resultId], references: [id])
  admitCard   AdmitCard? @relation(fields: [admitCardId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([resultId])
  @@index([admitCardId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  userId    String
  jobId     String?
  resultId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  job       Job?     @relation(fields: [jobId], references: [id])
  result    Result?  @relation(fields: [resultId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@index([resultId])
}

model Log {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([entity])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  excerpt   String?
  content   String?
  author    String   @default("Chayan Team")
  image     String?
  tags      String?
  published Boolean  @default(false)
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([createdAt])
}

model JobView {
  id     String   @id @default(cuid())
  jobId  String
  views  Int      @default(0)
  date   DateTime @default(now())
  job    Job      @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([date])
}
